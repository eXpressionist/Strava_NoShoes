# Strava API Configuration for the second instance
STRAVA_CLIENT_ID=your_second_client_id_here
STRAVA_CLIENT_SECRET=your_second_client_secret_here
STRAVA_ACCESS_TOKEN=your_second_access_token_here
STRAVA_REFRESH_TOKEN=your_second_refresh_token_here
STRAVA_TOKEN_EXPIRES_AT=0
STRAVA_TOKEN_FILE=/app/data/strava_tokens-secondary.json

# Use a different Telegram token, or leave empty to disable the bot.
BOT_API_TOKEN=
BOT_STATE_FILE=/app/data/bot_state-secondary.json

# The container listens on 8000. Docker publishes it as localhost:8001.
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

GPX_STORAGE_PATH=/app/data/gpx-secondary
GPX_CLEANUP_ENABLED=true
GPX_CLEANUP_SCHEDULE_HOUR=3
GPX_CLEANUP_SCHEDULE_MINUTE=0

DATABASE_URL=sqlite:////app/data/strava_noshoes-secondary.db
