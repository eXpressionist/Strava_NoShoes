# Strava API Configuration (needed only for initial backup migration)
# Get these values from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_ACCESS_TOKEN=your_access_token_here
STRAVA_REFRESH_TOKEN=your_refresh_token_here

# Garmin Connect Configuration
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password_here
GARMIN_TOKEN_STORE=data/garmin_tokens

# Telegram Bot Configuration
BOT_API_TOKEN=your_telegram_bot_token_here

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# File Storage
GPX_STORAGE_PATH=./data/gpx

# GPX Cleanup Configuration
GPX_CLEANUP_ENABLED=true
GPX_CLEANUP_SCHEDULE_HOUR=3
GPX_CLEANUP_SCHEDULE_MINUTE=0

# Database
DATABASE_URL=sqlite:///./strava_noshoes.db

# Migration cutoff: activities before this date come from SQLite (Strava backup),
# activities after — from Garmin API
MIGRATION_CUTOFF=2025-06-30